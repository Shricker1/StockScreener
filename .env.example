# Tushare 配置（第三方服务）
TUSHARE_TOKEN=YOUR_TUSHARE_TOKEN
TUSHARE_API_URL=https://your-tushare-endpoint

# AkShare 配置（可选）
# 若使用默认 AkShare 官方接口，可留空
AKSHARE_API_URL=
AKSHARE_TIMEOUT=30

# 主数据源：akshare（默认，公开接口无需 API Key）或 tushare（需下方 TOKEN）
DATA_SOURCE=akshare

# 拉取优先级（逗号分隔）：默认 Tushare 优先（需 TOKEN），其余为回退
#   - tushare: 需 TUSHARE_TOKEN
#   - akshare_em / akshare: 东财接口，全市场列表与日线
#   - akshare_sina: 新浪日线
#   - tencent: 腾讯日线（可能缺 volume）
#   - efinance: 需 pip install efinance
DATA_SOURCE_PRIORITY=tushare,akshare_em,akshare_sina,tencent,efinance

# 可选扩展数据服务（占位值）
TICKFLOW_API_KEY=YOUR_TICKFLOW_API_KEY
TICKFLOW_BASE_URL=https://your-tickflow-endpoint
TICKFLOW_USE_KLINE_FALLBACK=true
TICKFLOW_USE_UNIVERSE_MARKET_STATS=true
TICKFLOW_MARKET_UNIVERSE=CN_Equity_A
#
# 兼容别名（可二选一，不建议两套都写）：
# TICKETFLOW_API_KEY=
# TICKETFLOW_BASE_URL=https://your-tickflow-endpoint
# TICKETFLOW_USE_KLINE_FALLBACK=true
# TICKETFLOW_USE_UNIVERSE_MARKET_STATS=true
# TICKETFLOW_MARKET_UNIVERSE=CN_Equity_A

# AI 服务配置（占位值）
AI_PROVIDER=your-provider
AI_API_KEY=YOUR_AI_API_KEY
AI_BASE_URL=https://your-ai-endpoint/v1
AI_MODEL=your-model
AI_MAX_TOKENS=8000
AI_TEMPERATURE=0.3
AI_MAX_CONTEXT_TOKENS=40000
AI_RESERVED_OUTPUT_TOKENS=2000
AI_TOKEN_SAFETY_MARGIN=200
AI_TOKEN_COUNT_METHOD=estimate

# 技术顾问AI（默认与主 AI 一致；密钥留空则复用 AI_API_KEY）
TECH_ADVISOR_PROVIDER=your-provider
TECH_ADVISOR_API_KEY=
TECH_ADVISOR_BASE_URL=https://your-ai-endpoint/v1
TECH_ADVISOR_MODEL=your-model
TECH_ADVISOR_TEMPERATURE=0.2
# 不限制可留空或写 none/null；会自动使用较大输出上限（4096）
AI_TECH_ADVISOR_MAX_TOKENS=

# 缠论 ChanAnalysis（可选；未安装 chan.py 时仅生成说明性报告，不阻断主流程）
CHANLUN_ENABLED=true
CHANLUN_AI_ENABLED=true
# CHANLUN_PLOT_DIR=./output_files/chanlun_plots
# 完整缠论需: pip install git+https://github.com/Vespa314/chan.py （建议 Python 3.11+）

# 辩论功能开关（true/false）
DEBATE_ENABLED=true

# 待分析股票列表：逗号分隔，或使用 hs300
STOCK_LIST=600519,000858,300750,002594,601318
